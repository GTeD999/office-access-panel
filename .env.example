# MikroTik REST API (http://IP:PORT without /rest)
MIKROTIK_HOST=http://192.168.1.1:8080
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD='your-password-here'

MIKROTIK_ALLOW_WRITE=false
MIKROTIK_DRY_RUN=true

# Panel access phrase — openssl rand -base64 48
# ACCESS_SECRET='your-long-secret-phrase'

# Bitrix24 incoming webhook
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-code/
BITRIX_DRY_RUN=true

REGRU_DRY_RUN=true
REGVPS_DRY_RUN=true

# VMware ESXi
# VMWARE_HOST=https://192.168.1.20
VMWARE_DRY_RUN=true

ACCOUNTS_DRY_RUN=true
