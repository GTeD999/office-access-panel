# MikroTik REST API (http://IP:PORT без /rest)
MIKROTIK_HOST=http://212.20.40.220:8080
MIKROTIK_USERNAME=admin
# Пароль в одинарных кавычках, если есть ", %, $ и т.д.
MIKROTIK_PASSWORD='your-password-here'

# Безопасность: по умолчанию только чтение
MIKROTIK_ALLOW_WRITE=false
MIKROTIK_DRY_RUN=true

# Локально только на вашем ПК — панель без входа (npm run dev → 127.0.0.1)
# PANEL_LOCAL_ONLY=true

# Фраза для WebFig MikroTik (не для панели!). openssl rand -base64 48
# MIKROTIK_GATE_SECRET='ваша-длинная-фраза'

# Устаревшее — вход в панель (не путать с MIKROTIK_GATE_SECRET):
# ACCESS_SECRET='...'

# Устаревший алиас (лучше ACCESS_SECRET):
# APP_PIN=1234

# Разрешить управление роутером с IP целых стран (VN = Вьетнам). См. README.
# MIKROTIK_MGMT_ALLOW_COUNTRIES=VN

# Bitrix24 облако — входящий вебхук (Настройки → Разработчикам → Входящий вебхук, права: user)
BITRIX24_WEBHOOK_URL=https://novactiv.bitrix24.ru/rest/1/ВАШ_КОД/
BITRIX_DRY_RUN=true
# ID администраторов, которых нельзя блокировать (через запятую). По умолчанию всегда исключаются 9 и 29.
# BITRIX_EXCLUDE_USER_IDS=9,29,1

# Удалённые экраны в браузере (Apache Guacamole). После установки Guacamole на сервере:
# MikroTik — доп. офисы (url для кнопки «Открыть WebFig»)
# MIKROTIK_SOV36_HOST=http://IP:8080
# MIKROTIK_LINE27_HOST=http://IP:8080

# Reg.ru — хостинги и выделенный сервер (логин/пароль из credentials или env)
# REGRU_USERNAME=info@novactiv.ru
# REGRU_PASSWORD=
REGRU_DRY_RUN=true
# Пароль панели ISPmanager, если Reg.ru API отдаёт устаревший (Хостинг → Доступы в ЛК):
# REGRU_HOSTING_PASSWORD_90856995=
# REGRU_HOSTING_PASSWORD_71157013=
# В Reg.ru обязательно: Настройки API → добавить IP сервера с панелью
# https://www.reg.ru/user/account/#/settings/api/

# Reg.ru Cloud VPS (Рег.облако) — только если есть облачные VPS, не хостинги
# REGVPS_API_TOKEN=
REGVPS_DRY_RUN=true

# VMware ESXi — гипервизор (credentials «Гипервизор VMware» или env)
# Из офиса/VPN: https://192.168.88.20
# Удалённо (NAT, whitelist 0_WL на MikroTik): https://212.20.40.220:8822
# VMWARE_HOST=https://212.20.40.220:8822
# VMWARE_AUTO_WHITELIST=true — добавить внешний IP панели в 0_WL через MikroTik API
# VMWARE_WHITELIST_IP= — фиксированный IP, если автоопределение не подходит
# VMWARE_USERNAME=root
# VMWARE_PASSWORD=
VMWARE_DRY_RUN=true
# VMWARE_PROTECT_VMS=имя-vm-не-выключать
# VMWARE_POWER_OFF_TYPE=GUEST_OS — мягкое выключение ОС (ползунок может оставаться «вкл» до завершения)

# Управление аккаунтами (вкладка «Аккаунты») — см. accounts.example.json → .data/accounts.json
# Avito API необязателен (нужен платный тариф). Без API — логин/пароль из хранилища + ссылки в ЛК.
# AVITO_CLIENT_ID=
# AVITO_CLIENT_SECRET=
# AVITO_USER_ID=
# CIAN_API_KEY_COMMERCIAL=
# CIAN_BALANCE_URL_COMMERCIAL=
# CIAN_API_KEY_RESIDENTIAL=
# YANDEX360_OAUTH_TOKEN= — OAuth: directory:read_users, directory:write_users, ya360_security:domain_sessions_write
# YANDEX360_ORG_ID=
ACCOUNTS_DRY_RUN=true
